{
  "name": "spok",
  "version": "1.3.1",
  "description": "AI-native system for spec-driven development",
  "keywords": [
    "spok",
    "specs",
    "cli",
    "ai",
    "development"
  ],
  "license": "MIT",
  "author": "Spok Contributors",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "spok": "./bin/spok.js"
  },
  "files": [
    "dist",
    "bin",
    "schemas",
    "assets/skills",
    "scripts/postinstall.js",
    "!dist/**/*.test.js",
    "!dist/**/__tests__",
    "!dist/**/*.map"
  ],
  "scripts": {
    "lint": "eslint src/",
    "build": "bun run build.js",
    "dev": "tsc --watch",
    "dev:cli": "bun run build && bun bin/spok.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "check": "bun harness.ts check",
    "fix": "bun harness.ts fix",
    "typecheck": "tsc --noEmit",
    "pre-commit": "bun harness.ts pre-commit",
    "ci": "bun harness.ts ci",
    "audit": "bun harness.ts audit",
    "acceptance": "bun harness.ts acceptance",
    "coverage": "bun harness.ts coverage",
    "complexity": "bun harness.ts complexity",
    "crap": "bun harness.ts crap",
    "arch": "bun harness.ts arch",
    "setup-hooks": "bun harness.ts setup-hooks",
    "clean": "bun harness.ts clean",
    "test:postinstall": "bun run scripts/postinstall.js",
    "prepare": "bun run build",
    "prepublishOnly": "bun run build",
    "postinstall": "bun run scripts/postinstall.js",
    "check:pack-version": "bun run scripts/pack-version-check.mjs",
    "release": "bun run release:ci",
    "release:ci": "bun run check:pack-version && bunx changeset publish",
    "changeset": "changeset"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.27.7",
    "@cucumber/cucumber": "^12.9.0",
    "@types/bun": "^1.3.0",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/ui": "^4.1.8",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@inquirer/core": "^10.2.2",
    "@inquirer/prompts": "^7.8.0",
    "chalk": "^5.5.0",
    "commander": "^14.0.0",
    "cross-spawn": "7.0.6",
    "fast-glob": "^3.3.3",
    "ora": "^8.2.0",
    "posthog-node": "^5.20.0",
    "yaml": "^2.8.2",
    "zod": "^4.0.17"
  }
}
